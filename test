-- MacroSystem/Abstraction/MapAdapter.lua
local MapAdapter = {}
MapAdapter.__index = MapAdapter

function MapAdapter.new(mapId: string, bounds: {Vector3}, anchors: {[string]: Vector3})
    local self = setmetatable({}, MapAdapter)
    self.MapId = mapId
    self.Bounds = bounds
    self.Anchors = anchors or {}
    return self
end

function MapAdapter:HasAnchor(anchorId: string): boolean
    return self.Anchors[anchorId] ~= nil
end

function MapAdapter:GetAnchorPosition(anchorId: string): Vector3?
    return self.Anchors[anchorId]
end

function MapAdapter:GetScaleFactor(): Vector3
    -- This defines how normalized offsets map to real studs.
    -- Assuming Bounds[1] is Min and Bounds[2] is Max
    if self.Bounds and #self.Bounds >= 2 then
        local size = self.Bounds[2] - self.Bounds[1]
        return size
    end
    return Vector3.new(100, 100, 100) -- Default fallback scale
end

