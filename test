-- MacroSystem/Execution/Executor.lua

local Executor = {}
Executor.__index = Executor

function Executor.new(actionQueue, conditionEvaluator, actionHandlers, mapAdapter)
    local self = setmetatable({}, Executor)
    self.Queue = actionQueue
    self.Evaluator = conditionEvaluator
    self.Handlers = actionHandlers
    self.Adapter = mapAdapter
    self.CurrentAction = nil
    self.ActionWaitStartTime = 0
    return self
end

function Executor:ProcessTick(currentTime: number)
    if not self.CurrentAction then
        self.CurrentAction = self.Queue:Dequeue()
        if self.CurrentAction then
            self.ActionWaitStartTime = currentTime
            Logger.debug("Dequeued new action: " .. self.CurrentAction.id)
        else
            return -- Queue empty
        end
    end

    local action = self.CurrentAction

    -- Validate conditions (Hybrid state + time sync)
    local ready = self.Evaluator:Evaluate(action.conditions, self.ActionWaitStartTime, currentTime)
    if not ready then
        return -- Still waiting for condition to be met
    end

    -- Execute Action
    Logger.info("Executing action: " .. action.id .. " type: " .. action.type)
    action.status = "running"
    
    local success, err = pcall(function()
        self.Handlers:Handle(action, self.Adapter)
    end)
    
    if success then
        action.status = "success"
        Logger.info("Action Success: " .. action.id)
        self.CurrentAction = nil
    else
        action.status = "failed"
        action.retries.count = action.retries.count + 1
        Logger.warn("Action Failed: " .. action.id .. " | Error: " .. tostring(err))
        
        if action.retries.count <= action.retries.max then
            Logger.info("Requeueing action: " .. action.id .. " (Retry " .. tostring(action.retries.count) .. ")")
            action.status = "pending"
            if not action.conditions then action.conditions = {} end
            -- Exponential or generic retry backoff can be formulated here
            action.conditions.delay = (action.conditions.delay or 0) + action.retries.delay
            self.Queue:Requeue(action)
        else
            Logger.error("Action max retries reached, failing: " .. action.id)
        end
        self.CurrentAction = nil
    end
end

