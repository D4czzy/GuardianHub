-- MacroSystem/Data/ActionSchema.lua
local ActionSchema = {}

export type Retries = {
    max: number,
    count: number,
    delay: number
}

export type ActionStatus = "pending" | "running" | "success" | "failed"

export type Condition = {
    wave: number?,
    minMoney: number?,
    unitExists: string?,
    gameState: string?,
    delay: number -- The hybrid delay
}

export type Action = {
    id: string,
    type: string,
    timestamp: number,
    payload: { [string]: any },
    conditions: Condition?,
    retries: Retries,
    status: ActionStatus
}

-- Strict contract validation
function ActionSchema.Validate(actionData: any): (boolean, string?)
    if type(actionData) ~= "table" then return false, "Action must be a table" end
    if type(actionData.id) ~= "string" then return false, "Missing or invalid id" end
    if type(actionData.type) ~= "string" then return false, "Missing or invalid type" end
    if type(actionData.timestamp) ~= "number" then return false, "Missing or invalid timestamp" end
    if type(actionData.payload) ~= "table" then return false, "Missing or invalid payload" end
    if type(actionData.retries) ~= "table" then return false, "Missing retries configuration" end
    if type(actionData.status) ~= "string" then return false, "Missing status" end

    return true
end

function ActionSchema.CreateAction(props: any): Action
    local ok, err = ActionSchema.Validate(props)
    if not ok then
        error("Action validation failed: " .. tostring(err))
    end
    -- Shallow clone and freeze (simulating immutability where possible)
    local action = table.clone(props)
    table.freeze(action.retries)
    if action.conditions then table.freeze(action.conditions) end
    table.freeze(action)
    return action
end

