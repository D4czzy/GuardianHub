local FileStore = {}

-- Mocking file persistence. In studio could use writefile if Executor, or DataStores/HttpService for normal game.
function FileStore.SaveMacro(name: string, mapId: string, actions: table, requiredAnchors: table): boolean
    local macroData = {
        version = "1.0",
        name = name,
        mapId = mapId,
        requiredAnchors = requiredAnchors or {},
        actions = actions
    }
    
    local json = Serializer.Serialize(macroData)
    -- Virtual storage for demonstration
    _G.VirtualFileStore = _G.VirtualFileStore or {}
    _G.VirtualFileStore[name] = json
    
    Logger.info("Saved macro: " .. name .. " for MapId: " .. mapId)
    return true
end

function FileStore.LoadMacro(name: string, currentMapAdapter: any): table?
    _G.VirtualFileStore = _G.VirtualFileStore or {}
    local json = _G.VirtualFileStore[name]
    
    if not json then
        Logger.error("Macro not found: " .. name)
        return nil
    end
    
    local data, err = Serializer.Deserialize(json)
    if not data then
        Logger.error("Failed to parse macro " .. name .. ": " .. tostring(err))
        return nil
    end
    
    -- Incompatibility Check
    for _, anchor in ipairs(data.requiredAnchors) do
        if not currentMapAdapter:HasAnchor(anchor) then
            Logger.warn("MACRO INCOMPATIBLE: Map is missing required anchor: " .. tostring(anchor))
            return nil
        end
    end
    
    Logger.info("Successfully loaded macro: " .. name)
    return data
end

function FileStore.ListMacros(): table
    _G.VirtualFileStore = _G.VirtualFileStore or {}
    local list = {}
    for name, _ in pairs(_G.VirtualFileStore) do
        table.insert(list, name)
    end
    return list
end

