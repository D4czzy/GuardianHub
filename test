-- MacroSystem/Detection/AGDetector.lua
local Players = game:GetService("Players")

local AGDetector = {}
AGDetector.__index = AGDetector

function AGDetector.new()
    local self = setmetatable({}, AGDetector)
    self.LocalPlayer = Players.LocalPlayer
    return self
end

function AGDetector:GetHUD()
    if not self.LocalPlayer then return nil end
    local pgui = self.LocalPlayer:FindFirstChild("PlayerGui")
    if pgui then
        -- Search for common Anime Guardians HUD structures
        local hud = pgui:FindFirstChild("MainUI") and pgui.MainUI:FindFirstChild("HUD")
        if not hud then
            hud = pgui:FindFirstChild("HUD") -- Fallback
        end
        return hud
    end
    return nil
end

function AGDetector:GetState()
    local hud = self:GetHUD()
    if hud and hud.Visible then
        return "InGame"
    end
    return "Lobby"
end

function AGDetector:GetCurrentWave()
    local hud = self:GetHUD()
    if hud then
        -- Target Anime Guardians Wave TextLabel
        local waveContainer = hud:FindFirstChild("WaveInfo") or hud:FindFirstChild("TopBar")
        if waveContainer then
            local waveLabel = waveContainer:FindFirstChild("Wave") or waveContainer:FindFirstChild("WaveText")
            if waveLabel and waveLabel:IsA("TextLabel") then
                -- Parse string like "Wave 15" -> 15
                local num = string.match(waveLabel.Text, "%d+")
                return tonumber(num) or 0
            end
        end
    end
    return 0 -- Default
end

function AGDetector:GetMoney()
    local hud = self:GetHUD()
    if hud then
        -- Target Anime Guardians Money TextLabel
        local moneyLabel = hud:FindFirstChild("Money") or (hud:FindFirstChild("BottomBar") and hud.BottomBar:FindFirstChild("Money"))
        if moneyLabel and moneyLabel:IsA("TextLabel") then
            -- Parse "5,000" -> 5000
            local clean = string.gsub(moneyLabel.Text, ",", "")
            return tonumber(clean) or 0
        end
    end
    -- Fallback to leaderstats just in case
    if self.LocalPlayer:FindFirstChild("leaderstats") and self.LocalPlayer.leaderstats:FindFirstChild("Money") then
        return self.LocalPlayer.leaderstats.Money.Value
    end
    return 0
end

