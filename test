-- MacroSystem/Core/ActionQueue.lua
local ActionQueue = {}
ActionQueue.__index = ActionQueue

function ActionQueue.new()
    local self = setmetatable({}, ActionQueue)
    self._queue = {}
    return self
end

function ActionQueue:Enqueue(action)
    -- Insert based on timestamp (priority queue behavior)
    local inserted = false
    for i, a in ipairs(self._queue) do
        if action.timestamp < a.timestamp then
            table.insert(self._queue, i, action)
            inserted = true
            break
        end
    end
    if not inserted then
        table.insert(self._queue, action)
    end
end

function ActionQueue:Dequeue()
    if #self._queue == 0 then return nil end
    return table.remove(self._queue, 1)
end

function ActionQueue:Peek()
    return self._queue[1]
end

function ActionQueue:Requeue(action)
    self:Enqueue(action)
end

function ActionQueue:Clear()
    table.clear(self._queue)
end

function ActionQueue:Count()
    return #self._queue
end

function ActionQueue:GetQueue()
    return self._queue
end

