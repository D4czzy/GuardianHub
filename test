-- MacroSystem/Abstraction/SpatialResolver.lua
local SpatialResolver = {}

function SpatialResolver.ResolvePosition(mapAdapter, anchorId: string?, offsetNormalized: any?, absolutePosition: Vector3?): Vector3
    -- Fallback for simple scripts (No Adapter logic)
    if not mapAdapter or not anchorId or not offsetNormalized then
        if absolutePosition then return absolutePosition end
        error("Missing Spatial Data: Neither MapAdapter nor AbsolutePosition provided.")
    end
    
    if not mapAdapter:HasAnchor(anchorId) then
        error("MapAdapter missing required anchor: " .. tostring(anchorId))
    end
    
    local anchorPos = mapAdapter:GetAnchorPosition(anchorId)
    local scale = mapAdapter:GetScaleFactor()
    
    local rx = (offsetNormalized.x or 0) * scale.X
    local ry = (offsetNormalized.y or 0) * scale.Y
    local rz = (offsetNormalized.z or 0) * scale.Z
    
    return anchorPos + Vector3.new(rx, ry, rz)
end

function SpatialResolver.NormalizePosition(mapAdapter, targetPos: Vector3): (string?, any?, Vector3?)
    -- Fallback for simple scripts
    if not mapAdapter or not mapAdapter.Anchors or next(mapAdapter.Anchors) == nil then
        return nil, nil, targetPos
    end

    local bestAnchor = nil
    local shortestDist = math.huge
    
    for id, pos in pairs(mapAdapter.Anchors) do
        local dist = (targetPos - pos).Magnitude
        if dist < shortestDist then
            shortestDist = dist
            bestAnchor = id
        end
    end
    
    if not bestAnchor then
        return nil, nil, targetPos
    end
    
    local anchorPos = mapAdapter:GetAnchorPosition(bestAnchor)
    local scale = mapAdapter:GetScaleFactor()
    local rawOffset = targetPos - anchorPos
    
    local offsetNormalized = {
        x = scale.X ~= 0 and (rawOffset.X / scale.X) or 0,
        y = scale.Y ~= 0 and (rawOffset.Y / scale.Y) or 0,
        z = scale.Z ~= 0 and (rawOffset.Z / scale.Z) or 0
    }
    
    return bestAnchor, offsetNormalized, nil
end

