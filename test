-- MacroSystem/Core/StateMachine.lua

local StateMachine = {}
StateMachine.__index = StateMachine

StateMachine.States = {
    Idle = "Idle",
    Recording = "Recording",
    Playing = "Playing",
    WaitingResult = "WaitingResult",
    Transition = "Transition",
    AutoLobby = "AutoLobby",
    Error = "Error"
}

function StateMachine.new()
    local self = setmetatable({}, StateMachine)
    self.CurrentState = StateMachine.States.Idle
    
    -- Instead of BindableEvent which might require instances, we use a simple listener array map
    self._listeners = {}
    return self
end

function StateMachine:TransitionTo(newState: string)
    if not StateMachine.States[newState] then
        Logger.error("Attempted transition to invalid state: " .. tostring(newState))
        return false
    end
    
    local oldState = self.CurrentState
    if oldState == newState then return false end
    
    Logger.info("FSM Transition: " .. oldState .. " -> " .. newState)
    self.CurrentState = newState
    
    for _, callback in ipairs(self._listeners) do
        task.spawn(callback, newState, oldState)
    end
    
    return true
end

function StateMachine:Subscribe(callback)
    table.insert(self._listeners, callback)
end

function StateMachine:GetState()
    return self.CurrentState
end

function StateMachine:Destroy()
    table.clear(self._listeners)
end

