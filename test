-- MacroSystem/Debug/Logger.lua
local Logger = {}
Logger.Level = {
    DEBUG = 1,
    INFO = 2,
    WARN = 3,
    ERROR = 4
}
Logger.CurrentLevel = Logger.Level.INFO

function Logger.log(level: number, message: string, data: any?)
    if level < Logger.CurrentLevel then return end
    
    local prefix = "[MACRO]"
    if level == Logger.Level.DEBUG then prefix = "[MACRO-DBG]"
    elseif level == Logger.Level.INFO then prefix = "[MACRO-INFO]"
    elseif level == Logger.Level.WARN then prefix = "[MACRO-WARN]"
    elseif level == Logger.Level.ERROR then prefix = "[MACRO-ERR]"
    end

    local msg = string.format("%s %s", prefix, message)
    if data then
        if level >= Logger.Level.ERROR then
            warn(msg, data)
        else
            print(msg, data)
        end
    else
        if level >= Logger.Level.ERROR then
            warn(msg)
        else
            print(msg)
        end
    end
end

function Logger.debug(msg: string, data: any?) Logger.log(Logger.Level.DEBUG, msg, data) end
function Logger.info(msg: string, data: any?) Logger.log(Logger.Level.INFO, msg, data) end
function Logger.warn(msg: string, data: any?) Logger.log(Logger.Level.WARN, msg, data) end
function Logger.error(msg: string, data: any?) Logger.log(Logger.Level.ERROR, msg, data) end

