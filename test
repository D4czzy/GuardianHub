-- MacroSystem/Detection/ConditionEvaluator.lua
local ConditionEvaluator = {}
ConditionEvaluator.__index = ConditionEvaluator

function ConditionEvaluator.new(gameStateDetector)
    local self = setmetatable({}, ConditionEvaluator)
    self.Detector = gameStateDetector
    return self
end

function ConditionEvaluator:Evaluate(condition: any, waitStartTime: number, currentTime: number): boolean
    if not condition then return true end
    
    -- Hybrid State + Time evaluation
    
    -- 1. Game State checking
    if condition.gameState and self.Detector:GetState() ~= condition.gameState then
        return false
    end
    
    -- 2. Wave Checking
    if condition.wave then
        local currentWave = self.Detector:GetCurrentWave()
        if currentWave < condition.wave then
            return false
        end
    end
    
    -- 3. Money Checking 
    if condition.minMoney then
        local currentMoney = self.Detector:GetMoney()
        if currentMoney < condition.minMoney then
            return false
        end
    end
    
    -- 4. Hybrid Time Delay
    if condition.delay then
        if currentTime < (waitStartTime + condition.delay) then
            return false
        end
    end
    
    return true
end

