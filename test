-- MacroSystem/Recording/Recorder.lua
local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")

local Recorder = {}
Recorder.__index = Recorder

function Recorder.new(stateMachine, mapAdapter, gameStateDetector)
    local self = setmetatable({}, Recorder)
    self.StateMachine = stateMachine
    self.Adapter = mapAdapter
    self.Detector = gameStateDetector
    self.RecordedActions = {}
    self.IsRecording = false
    self.OriginalNamecall = nil
    self._connections = {}
    return self
end

function Recorder:StartRecording()
    if self.IsRecording then return end
    self.IsRecording = true
    table.clear(self.RecordedActions)
    Logger.info("Recording Started.")
    
    -- Safe Hook System: Check for getrawmetatable availability natively
    local success, mt = pcall(getrawmetatable, game)
    if not success or not mt then
        Logger.warn("[Safe Hook Fallback Active] getrawmetatable unsupported on this executor. Switching to Mouse Click Recording.")
        self:StartFallbackRecording()
        return
    end
    
    setreadonly(mt, false)
    self.OriginalNamecall = mt.__namecall
    
    local oldNamecall = self.OriginalNamecall
    mt.__namecall = newcclosure(function(self_obj, ...)
        local method = getnamecallmethod()
        local args = {...}
        
        if self.IsRecording and typeof(self_obj) == "Instance" and (self_obj:IsA("RemoteEvent") or self_obj:IsA("RemoteFunction")) then
            if method == "InvokeServer" or method == "FireServer" then
                local remoteName = self_obj.Name
                task.spawn(function()
                    self:ProcessInterceptedRemote(remoteName, args)
                end)
            end
        end
        return oldNamecall(self_obj, ...)
    end)
    setreadonly(mt, true)
    Logger.info("Advanced __namecall interception active.")
end

function Recorder:StartFallbackRecording()
    -- Native Mouse Click recording commonly found in pastebin scripts
    local mouse = Players.LocalPlayer:GetMouse()
    local conn = UserInputService.InputBegan:Connect(function(input, gpe)
        if gpe then return end
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            -- Fallback blind assumption: User clicks to place unit. 
            -- Because we can't intercept network natively here, we guess the selected unit.
            local placementPos = mouse.Hit.Position
            local mockUnit = "Unit_" .. tostring(math.random(100, 999))
            local action = ActionNormalizer.NormalizePlacement(placementPos, self.Adapter, mockUnit)
            self:RecordAction(action)
            Logger.info("Fallback Mouse Recorded: " .. tostring(placementPos))
        end
    end)
    table.insert(self._connections, conn)
end

function Recorder:ProcessInterceptedRemote(remoteName, args)
    if remoteName == "PlaceUnit" or remoteName == "SpawnUnit" then
        local unitId = args[1]
        local position = args[2]
        if typeof(position) == "Vector3" then
            local action = ActionNormalizer.NormalizePlacement(position, self.Adapter, tostring(unitId))
            self:RecordAction(action)
        end
    elseif remoteName == "UpgradeUnit" then
        local uuid = args[1]
        local action = ActionNormalizer.NormalizeUpgrade(tostring(uuid))
        self:RecordAction(action)
    elseif remoteName == "SellUnit" then
        local action = ActionNormalizer.NormalizeSkill(tostring(args[1]), "sell") 
        action.type = "sell_unit"
        self:RecordAction(action)
    end
end

function Recorder:StopRecording()
    if not self.IsRecording then return end
    self.IsRecording = false
    
    if self.OriginalNamecall then
        local success, mt = pcall(getrawmetatable, game)
        if success and mt then
            setreadonly(mt, false)
            mt.__namecall = self.OriginalNamecall
            setreadonly(mt, true)
        end
        self.OriginalNamecall = nil
    end
    
    for _, conn in ipairs(self._connections) do
        conn:Disconnect()
    end
    table.clear(self._connections)
    
    Logger.info("Recording Stopped. Total Actions: " .. tostring(#self.RecordedActions))
end

function Recorder:RecordAction(action: any)
    if not self.IsRecording then return end
    
    local currentWave = self.Detector:GetCurrentWave()
    local safeAction = table.clone(action)
    local conditions = safeAction.conditions and table.clone(safeAction.conditions) or {}
    conditions.wave = currentWave
    
    safeAction.conditions = conditions
    table.insert(self.RecordedActions, safeAction)
    Logger.debug("Recorded action: " .. safeAction.type)
end

function Recorder:GetRecording()
    return self.RecordedActions
end

