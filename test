-- MacroSystem/Recording/ActionNormalizer.lua

local ActionNormalizer = {}

function ActionNormalizer.NormalizePlacement(rawPos: Vector3, mapAdapter: any, unitId: string): any
    local anchor, offset, absolutePos = SpatialResolver.NormalizePosition(mapAdapter, rawPos)
    
    local payload = { unitId = unitId }
    if anchor and offset then
        payload.anchor = anchor
        payload.offsetNormalized = offset
    else
        payload.absolutePosition = absolutePos
    end
    
    local actionData = {
        id = game:GetService("HttpService"):GenerateGUID(false),
        type = "place_unit",
        timestamp = os.clock(),
        payload = payload,
        conditions = { delay = 0 },
        retries = { max = 3, count = 0, delay = 1 },
        status = "pending"
    }
    
    return ActionSchema.CreateAction(actionData)
end

