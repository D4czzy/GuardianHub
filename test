-- MacroSystem/Data/Serializer.lua
local HttpService = game:GetService("HttpService")

local Serializer = {}

-- Serialize for saving to JSON
function Serializer.Serialize(macroData: any): string
    return HttpService:JSONEncode(macroData)
end

-- Deserialize from JSON and validate schema implicitly
function Serializer.Deserialize(jsonString: string): (any, string?)
    local success, result = pcall(function()
        return HttpService:JSONDecode(jsonString)
    end)
    if not success then return nil, "Failed to decode JSON" end
    
    -- Re-validate all actions
    if result.actions then
        for i, rawAction in ipairs(result.actions) do
            local ok, err = ActionSchema.Validate(rawAction)
            if not ok then
                return nil, "Invalid action at index " .. i .. ": " .. tostring(err)
            end
        end
    end
    
    return result
end

