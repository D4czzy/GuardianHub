-- MacroSystem/Core/Scheduler.lua
local RunService = game:GetService("RunService")

local Scheduler = {}
Scheduler.__index = Scheduler

function Scheduler.new(executor, stateMachine)
    local self = setmetatable({}, Scheduler)
    self.Executor = executor
    self.StateMachine = stateMachine
    self.StartTime = 0
    self.CurrentTime = 0
    self.IsRunning = false
    self.IsPaused = false
    self._connection = nil
    return self
end

function Scheduler:Start()
    if self.IsRunning then return end
    self.IsRunning = true
    self.IsPaused = false
    self.StartTime = os.clock()
    self.CurrentTime = 0
    
    Logger.info("Scheduler Started.")
    self._connection = RunService.Heartbeat:Connect(function(dt)
        self:OnHeartbeat(dt)
    end)
end

function Scheduler:Pause()
    self.IsPaused = true
    Logger.info("Scheduler Paused.")
end

function Scheduler:Resume()
    self.IsPaused = false
    Logger.info("Scheduler Resumed.")
end

function Scheduler:Stop()
    self.IsRunning = false
    self.IsPaused = false
    if self._connection then
        self._connection:Disconnect()
        self._connection = nil
    end
    Logger.info("Scheduler Stopped.")
end

function Scheduler:FastForward(seconds: number)
    self.CurrentTime = self.CurrentTime + seconds
    Logger.info("Scheduler Fast Forwarded by " .. tostring(seconds) .. "s")
end

function Scheduler:OnHeartbeat(dt: number)
    if not self.IsRunning or self.IsPaused then return end
    
    self.CurrentTime = self.CurrentTime + dt
    
    -- Check if FSM is in Playing state
    if self.StateMachine:GetState() ~= "Playing" then return end
    
    -- Tell executor to process available actions
    if self.Executor then
        self.Executor:ProcessTick(self.CurrentTime)
    end
end

