-- MacroSystem/MacroSystem.lua
-- Main API Gateway for the Automation Engine






local MacroSystem = {}
MacroSystem.__index = MacroSystem

function MacroSystem.new(mapAdapter)
    local self = setmetatable({}, MacroSystem)
    
    -- Initialize dependencies
    self.MapAdapter = mapAdapter
    self.FSM = StateMachine.new()
    self.Queue = ActionQueue.new()
    self.Detector = AGDetector.new()
    self.Evaluator = ConditionEvaluator.new(self.Detector)
    
    self.Handlers = AGHandlers.new()
    self.Handlers:RegisterDefaults()
    
    self.Executor = Executor.new(self.Queue, self.Evaluator, self.Handlers, self.MapAdapter)
    self.Scheduler = Scheduler.new(self.Executor, self.FSM)
    self.Recorder = Recorder.new(self.FSM, self.MapAdapter, self.Detector)
    self.UI = UIController.new(self)
    
    self.AutoJoinConfig = nil
    
    -- AutoReplay Hook
    self.FSM:Subscribe(function(newState, oldState)
        if newState == "Idle" and oldState == "Playing" and self.AutoJoinConfig then
            Logger.info("AutoReplay Triggered: Attempting return to Lobby...")
            -- game:GetService("ReplicatedStorage"):WaitForChild("Remotes"):WaitForChild("ReturnToLobby"):InvokeServer()
            self.FSM:TransitionTo("AutoLobby")
            self:_startAutoLobbyLoop()
        end
    end)
    
    Logger.info("Spatially Abstracted Deterministic Automation Engine Initialized")
    return self
end

function MacroSystem:EnableAutoJoin(mapTarget: string, difficulty: string)
    self.AutoJoinConfig = { map = mapTarget, difficulty = difficulty }
    if self.FSM:GetState() == "Idle" or self.FSM:GetState() == "AutoLobby" then
        self.FSM:TransitionTo("AutoLobby")
        self:_startAutoLobbyLoop()
    end
end

function MacroSystem:DisableAutoJoin()
    self.AutoJoinConfig = nil
    if self.FSM:GetState() == "AutoLobby" then self.FSM:TransitionTo("Idle") end
end

function MacroSystem:_startAutoLobbyLoop()
    task.spawn(function()
        while self.FSM:GetState() == "AutoLobby" do
            task.wait(2)
            local state = self.Detector:GetState()
            
            if state == "Lobby" then
                Logger.info("AutoLobby: Attempting to join map " .. tostring(self.AutoJoinConfig.map))
                -- game:GetService("ReplicatedStorage"):WaitForChild("Remotes"):WaitForChild("JoinMap"):InvokeServer(self.AutoJoinConfig.map, self.AutoJoinConfig.difficulty)
            elseif state == "InGame" then
                Logger.info("AutoLobby: Successfully entered game. Auto-starting macro playback...")
                self:Play("DemoMacro") 
                break
            end
        end
    end)
end

function MacroSystem:StartUI()
    self.UI:Initialize()
end

function MacroSystem:ToggleAntiAFK(state: boolean)
    local Players = game:GetService("Players")
    local VirtualUser = game:GetService("VirtualUser")
    
    if state then
        self.AntiAfkConn = Players.LocalPlayer.Idled:Connect(function()
            -- Captures the input controller to send a virtually undetectable ghost click, preventing the 20min timeout.
            VirtualUser:CaptureController()
            VirtualUser:ClickButton2(Vector2.new())
            Logger.info("Anti-AFK By-pass triggered ghost input.")
        end)
    else
        if self.AntiAfkConn then
            self.AntiAfkConn:Disconnect()
            self.AntiAfkConn = nil
        end
    end
end

function MacroSystem:ToggleCPUSaver(state: boolean)
    local success, err = pcall(function()
        game:GetService("RunService"):Set3dRenderingEnabled(not state)
    end)
    if not success then
        Logger.warn("Set3dRenderingEnabled unsupported on this device. CPU Saver failed.")
    end
end

function MacroSystem:StartRecording()
    if self.FSM:TransitionTo("Recording") then
        self.Recorder:StartRecording()
    end
end

function MacroSystem:Stop()
    local oldState = self.FSM:GetState()
    if self.FSM:TransitionTo("Idle") then
        self.Scheduler:Stop()
        self.Recorder:StopRecording()
        self.Queue:Clear()
    end
    return oldState
end

function MacroSystem:SaveRecording(name: string, mapId: string)
    local actions = self.Recorder:GetRecording()
    if #actions == 0 then
        Logger.warn("No actions to save.")
        return false
    end
    
    local requiredAnchors = {}
    -- Collect required anchors from placements
    for _, action in ipairs(actions) do
        if action.type == "place_unit" and action.payload.anchor then
            requiredAnchors[action.payload.anchor] = true
        end
    end
    
    local anchorList = {}
    for anchor, _ in pairs(requiredAnchors) do table.insert(anchorList, anchor) end
    
    return FileStore.SaveMacro(name, mapId, actions, anchorList)
end

function MacroSystem:Play(name: string)
    local macroData = FileStore.LoadMacro(name, self.MapAdapter)
    if not macroData then return false end
    
    if self.FSM:TransitionTo("Playing") then
        self.Queue:Clear()
        for _, action in ipairs(macroData.actions) do
            self.Queue:Enqueue(action)
        end
        self.Scheduler:Start()
        Logger.info("Playing macro: " .. name .. " with " .. tostring(self.Queue:Count()) .. " actions.")
        return true
    end
    return false
end

function MacroSystem:GetState()
    return self.FSM:GetState()
end

-- Pass-through to simulate hooks for external usage
function MacroSystem:RecordAction(action)
    self.Recorder:RecordAction(action)
end

