-- MacroSystem/Execution/AGHandlers.lua
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local AGHandlers = {}
AGHandlers.__index = AGHandlers

function AGHandlers.new()
    local self = setmetatable({}, AGHandlers)
    
    -- Target Anime Guardians Remote Storage location
    self.Remotes = ReplicatedStorage:WaitForChild("Remotes", 5)
    
    self._handlers = {}
    return self
end

function AGHandlers:RegisterHandler(actionType: string, handlerFn: any)
    self._handlers[actionType] = handlerFn
end

function AGHandlers:Handle(action: any, mapAdapter: any)
    local handler = self._handlers[action.type]
    if not handler then
        error("No handler registered for action type: " .. tostring(action.type))
    end
    handler(action.payload, mapAdapter, self.Remotes)
end

function AGHandlers:RegisterDefaults()
    self:RegisterHandler("place_unit", function(payload, mapAdapter, remotes)
        local position = payload.absolutePosition or SpatialResolver.ResolvePosition(mapAdapter, payload.anchor, payload.offsetNormalized)
        Logger.info(string.format("AG Action: PlaceUnit %s at %s", tostring(payload.unitId), tostring(position)))
        
        -- Exact Anime Guardians Invoke
        if remotes then
            remotes:WaitForChild("PlaceUnit"):InvokeServer(payload.unitId, position, CFrame.new())
        end
    end)

    self:RegisterHandler("upgrade_unit", function(payload, mapAdapter, remotes)
        Logger.info("AG Action: UpgradeUnit " .. tostring(payload.uuid))
        if remotes then
            remotes:WaitForChild("UpgradeUnit"):InvokeServer(payload.uuid)
        end
    end)

    self:RegisterHandler("sell_unit", function(payload, mapAdapter, remotes)
        Logger.info("AG Action: SellUnit " .. tostring(payload.uuid))
        if remotes then
            remotes:WaitForChild("SellUnit"):InvokeServer(payload.uuid)
        end
    end)

    self:RegisterHandler("change_targeting", function(payload, mapAdapter, remotes)
        Logger.info("AG Action: ChangeTargeting " .. tostring(payload.uuid) .. " to " .. tostring(payload.targetMode))
        if remotes then
            remotes:WaitForChild("ChangeTargeting"):InvokeServer(payload.uuid, payload.targetMode)
